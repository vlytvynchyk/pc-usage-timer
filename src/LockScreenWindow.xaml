<Window x:Class="PcUsageTimer.LockScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" WindowState="Maximized" Topmost="True"
        AllowsTransparency="False" Background="#12141A"
        ShowInTaskbar="False" ResizeMode="NoResize"
        FontFamily="Segoe UI"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        Deactivated="Window_Deactivated"
        Loaded="Window_Loaded">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Big clock icon -->
            <TextBlock Text="&#x23F0;" FontSize="100" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Time's Up!" FontSize="72" FontWeight="Bold"
                       Foreground="#E5484D" HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Your screen time has ended." FontSize="22"
                       Foreground="#788296" HorizontalAlignment="Center"
                       Margin="0,0,0,50"/>

            <TextBlock Text="Enter PIN to unlock" FontSize="15"
                       Foreground="#555B6E" HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <PasswordBox x:Name="PinEntry" FontSize="24" Width="180" Height="46"
                             MaxLength="4" Background="#232739" Foreground="#E6EBF5"
                             BorderBrush="#373C48" CaretBrush="#E6EBF5"
                             BorderThickness="1.2"
                             VerticalContentAlignment="Center" Padding="12,0"
                             KeyDown="PinEntry_KeyDown"/>

                <Button Content="Unlock" FontSize="16" FontWeight="Bold"
                        Width="110" Height="46" Margin="10,0,0,0"
                        Cursor="Hand" Click="UnlockButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#3A82F6" CornerRadius="6" Padding="10"
                                    BorderBrush="#3A82F6" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#64A5FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                </Button>
            </StackPanel>

            <TextBlock x:Name="ErrorText" FontSize="14" Foreground="#E5484D"
                       HorizontalAlignment="Center" Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>
