<Window x:Class="PcUsageTimer.LockScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" WindowState="Maximized" Topmost="True"
        AllowsTransparency="False" Background="#11111B"
        ShowInTaskbar="False" ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        Deactivated="Window_Deactivated"
        Loaded="Window_Loaded">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Big clock icon -->
            <TextBlock Text="&#x23F0;" FontSize="100" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Time's Up!" FontSize="80" FontWeight="Bold"
                       Foreground="#F38BA8" HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Your screen time has ended." FontSize="26"
                       Foreground="#A6ADC8" HorizontalAlignment="Center"
                       Margin="0,0,0,50"/>

            <TextBlock Text="Enter PIN to unlock" FontSize="18"
                       Foreground="#6C7086" HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <PasswordBox x:Name="PinEntry" FontSize="28" Width="180" Height="50"
                             MaxLength="4" Background="#313244" Foreground="#CDD6F4"
                             BorderBrush="#45475A" CaretBrush="#CDD6F4"
                             VerticalContentAlignment="Center" Padding="10,0"
                             KeyDown="PinEntry_KeyDown"/>

                <Button Content="Unlock" FontSize="20" FontWeight="Bold"
                        Width="120" Height="50" Margin="10,0,0,0"
                        Cursor="Hand" Click="UnlockButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#A6E3A1" CornerRadius="8" Padding="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#1E1E2E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="#1E1E2E"/>
                    </Button.Foreground>
                </Button>
            </StackPanel>

            <TextBlock x:Name="ErrorText" FontSize="16" Foreground="#F38BA8"
                       HorizontalAlignment="Center" Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>
