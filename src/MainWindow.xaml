<Window x:Class="PcUsageTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Usage Timer" Height="580" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        SizeToContent="Height"
        Icon="Assets/app-icon.png"
        Background="#1B1E24"
        FontFamily="Segoe UI"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <Style x:Key="PresetButton" TargetType="Button">
            <Setter Property="Background" Value="#232739"/>
            <Setter Property="Foreground" Value="#E6EBF5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="10"
                                BorderBrush="#373C48" BorderThickness="1.2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#303E3E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3A82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="10"
                                BorderBrush="#3A82F6" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#64A5FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2A6AD4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StopButton" TargetType="Button">
            <Setter Property="Background" Value="#1B1E24"/>
            <Setter Property="Foreground" Value="#3A82F6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="10"
                                BorderBrush="#3A82F6" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E2530"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#253040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E6EBF5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CheckBorder" Width="20" Height="20"
                                    CornerRadius="4" BorderThickness="1.5"
                                    BorderBrush="#464B5A" Background="Transparent">
                                <Path x:Name="CheckMark" Visibility="Collapsed"
                                      Stroke="White" StrokeThickness="2.2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M4,10 L8,14 L16,5"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#3A82F6"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#3A82F6"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="32,20,32,20">
        <!-- Setup Panel -->
        <StackPanel x:Name="SetupPanel">
            <TextBlock Text="PC Usage Timer" FontSize="20" FontWeight="Bold"
                       Foreground="#E6EBF5" HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <TextBlock Text="Select Duration" FontSize="13" Foreground="#788296" Margin="0,0,0,8"/>

            <UniformGrid Columns="3">
                <Button Content="10 min" Style="{StaticResource PresetButton}" Click="PresetButton_Click" Tag="10"/>
                <Button Content="20 min" Style="{StaticResource PresetButton}" Click="PresetButton_Click" Tag="20"/>
                <Button Content="30 min" Style="{StaticResource PresetButton}" Click="PresetButton_Click" Tag="30"/>
            </UniformGrid>

            <TextBlock Text="Or enter custom minutes:" FontSize="11" Foreground="#788296" Margin="0,14,0,5"/>
            <TextBox x:Name="CustomMinutesBox" FontSize="15" Height="40" Background="#232739"
                     Foreground="#E6EBF5" BorderBrush="#373C48" CaretBrush="#E6EBF5"
                     BorderThickness="1.2" FontFamily="Segoe UI"
                     VerticalContentAlignment="Center" Padding="12,0"
                     PreviewTextInput="NumericOnly_PreviewTextInput"/>

            <TextBlock Text="Set PIN (4 digits)" FontSize="13" Foreground="#788296" Margin="0,18,0,5"/>
            <PasswordBox x:Name="PinBox" FontSize="15" Height="40" MaxLength="4"
                         Background="#232739" Foreground="#E6EBF5" BorderBrush="#373C48"
                         CaretBrush="#E6EBF5" BorderThickness="1.2"
                         VerticalContentAlignment="Center" Padding="12,0"/>

            <TextBlock Text="Confirm PIN" FontSize="13" Foreground="#788296" Margin="0,10,0,5"/>
            <PasswordBox x:Name="PinConfirmBox" FontSize="15" Height="40" MaxLength="4"
                         Background="#232739" Foreground="#E6EBF5" BorderBrush="#373C48"
                         CaretBrush="#E6EBF5" BorderThickness="1.2"
                         VerticalContentAlignment="Center" Padding="12,0"/>

            <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#E5484D"
                       Margin="0,8,0,0" TextWrapping="Wrap"/>

            <Button Content="START TIMER" Style="{StaticResource ActionButton}"
                    Margin="0,18,0,0" Click="StartButton_Click"/>

            <!-- Separator -->
            <Border Height="1" Background="#2A2E38" Margin="0,20,0,16"/>

            <!-- Remote Lock Server Info -->
            <TextBlock Text="Remote Lock" FontSize="13" FontWeight="Bold"
                       Foreground="#E6EBF5" Margin="0,0,0,6"/>
            <TextBlock x:Name="RemoteLockStatusText" FontSize="11" Foreground="#788296"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="RemoteLockUrlText" FontSize="13" Foreground="#3A82F6"
                       FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap"/>
            <Image x:Name="QrCodeImage" Width="140" Height="140" Margin="0,8,0,0"
                   HorizontalAlignment="Left"/>

            <!-- Separator -->
            <Border Height="1" Background="#2A2E38" Margin="0,16,0,12"/>

            <!-- Auto-Start -->
            <CheckBox x:Name="AutoStartCheckBox" Content="Start with Windows"
                      Style="{StaticResource DarkCheckBox}"
                      Checked="AutoStartCheckBox_Changed" Unchecked="AutoStartCheckBox_Changed"/>
            <TextBlock Text="Launches minimized to system tray on login"
                       FontSize="11" Foreground="#788296" Margin="30,4,0,0"/>
        </StackPanel>

        <!-- Timer Running Panel -->
        <StackPanel x:Name="TimerPanel" Visibility="Collapsed" VerticalAlignment="Center">
            <TextBlock Text="Time Remaining" FontSize="16" Foreground="#788296"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <TextBlock x:Name="CountdownText" Text="00:00" FontSize="64" FontWeight="Bold"
                       Foreground="#3A82F6" HorizontalAlignment="Center" Margin="0,0,0,28"
                       FontFamily="Segoe UI"/>

            <Button Content="STOP TIMER" Style="{StaticResource StopButton}"
                    Click="StopButton_Click"/>

            <Border Height="1" Background="#2A2E38" Margin="0,20,0,16"/>

            <TextBlock Text="Remote Lock" FontSize="11" Foreground="#788296"/>
            <TextBlock x:Name="TimerRemoteLockUrl" FontSize="13" Foreground="#3A82F6"
                       FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
