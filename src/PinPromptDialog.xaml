<Window x:Class="PcUsageTimer.PinPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter PIN" Height="260" Width="350"
        Icon="Assets/app-icon.png"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E2E">

    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Enter PIN to stop the timer" FontSize="16"
                   Foreground="#CDD6F4" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <PasswordBox x:Name="PinEntry" FontSize="22" Height="40" MaxLength="4"
                     Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                     CaretBrush="#CDD6F4" VerticalContentAlignment="Center"
                     Padding="10,0" KeyDown="PinEntry_KeyDown"/>

        <TextBlock x:Name="ErrorText" FontSize="13" Foreground="#F38BA8"
                   HorizontalAlignment="Center" Margin="0,8,0,0"/>

        <Button Content="Confirm" FontSize="16" FontWeight="Bold" Height="40"
                Margin="0,12,0,0" Cursor="Hand" Click="ConfirmButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#A6E3A1" CornerRadius="6" Padding="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <Button.Foreground>
                <SolidColorBrush Color="#1E1E2E"/>
            </Button.Foreground>
        </Button>
    </StackPanel>
</Window>
