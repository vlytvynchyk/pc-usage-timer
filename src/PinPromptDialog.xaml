<Window x:Class="PcUsageTimer.PinPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter PIN" Height="240" Width="340"
        Icon="Assets/app-icon.png"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1B1E24" FontFamily="Segoe UI">

    <StackPanel Margin="32,20" VerticalAlignment="Center">
        <TextBlock Text="Enter PIN to stop the timer" FontSize="14"
                   Foreground="#E6EBF5" HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <PasswordBox x:Name="PinEntry" FontSize="18" Height="40" MaxLength="4"
                     Background="#232739" Foreground="#E6EBF5" BorderBrush="#373C48"
                     CaretBrush="#E6EBF5" BorderThickness="1.2"
                     VerticalContentAlignment="Center"
                     Padding="12,0" KeyDown="PinEntry_KeyDown"/>

        <TextBlock x:Name="ErrorText" FontSize="11" Foreground="#E5484D"
                   HorizontalAlignment="Center" Margin="0,8,0,0"/>

        <Button Content="Confirm" FontSize="14" FontWeight="Bold" Height="40"
                Margin="0,14,0,0" Cursor="Hand" Click="ConfirmButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#3A82F6" CornerRadius="6" Padding="8"
                            BorderBrush="#3A82F6" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#64A5FF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <Button.Foreground>
                <SolidColorBrush Color="White"/>
            </Button.Foreground>
        </Button>
    </StackPanel>
</Window>
